# Copie para .env e ajuste conforme necessário:
#   cp .env.example .env

# Porta do Vite em desenvolvimento (padrão: 5173)
# O Tauri usa a mesma porta automaticamente ao rodar `npm run tauri dev` ou `make app`.
VITE_DEV_PORT=5173

# Escuta na rede local (0.0.0.0). Use false para aceitar só localhost.
# Com true, acesse de outro dispositivo via http://<IP-da-máquina>:5173
VITE_DEV_HOST=true
