# Copie para .env e ajuste conforme necessário:
#   cp .env.example .env
#
# Usado por:
#   - desenvolvimento local (make dev / make start)
#   - Docker Compose (make docker-up → --env-file server/.env)

# --- Servidor HTTP ---

# Porta HTTP (local e Docker; no Docker mapeia host:container)
PORT=3001

# Interface de escuta (0.0.0.0 = todas as interfaces)
HOST=0.0.0.0

# Ambiente de execução
NODE_ENV=development

# --- MariaDB / banco ---

# Local: localhost | Docker: sobrescrito para "mariadb" no compose
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fluxor
DB_USER=fluxor
DB_PASSWORD=fluxor_dev_password

# Apenas MariaDB no Docker (usuário root do container)
MARIADB_ROOT_PASSWORD=fluxor_root_password
